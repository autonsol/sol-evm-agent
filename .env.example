# Sol EVM Trading Agent — Environment Variables
# Copy to .env for local development

# REQUIRED for live trading (March 30)
EVM_PRIVATE_KEY=0x...              # Base wallet private key
RISK_ROUTER_ADDRESS=0x...          # Set from hackathon Discord on March 30

# OPTIONAL overrides
PAPER_MODE=true                    # Default: true (safe). Set false on March 30.
BASE_RPC_URL=https://mainnet.base.org
POLL_INTERVAL_MS=60000             # 60s scan interval
MAX_CONCURRENT_POSITIONS=3
POSITION_SIZE_USD=50
MIN_RISK_SCORE=65                  # Max acceptable risk score (0-100)
PORT=3030

# Time filter (UTC hours to block trading — low volume periods)
# Default: block overnight 0-7 UTC
BLOCKED_HOURS_UTC=0,1,2,3,4,5,6,7
